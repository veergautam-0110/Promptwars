rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Footprints collection
    match /footprints/{footprintId} {
      allow read: if isDocOwner();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // Goals collection
    match /goals/{goalId} {
      allow read: if isDocOwner();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    // Achievements collection
    match /achievements/{achievementId} {
      allow read: if isDocOwner();
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isDocOwner();
    }

    // Insights collection
    match /insights/{insightId} {
      allow read: if isDocOwner();
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isDocOwner();
    }
  }
}
